# ==========================================
# Model 4: Alpha-Omega Kinetic Simulation Configuration
# Monte Carlo Sampling with Empirical GPC Data
# ==========================================

# --- 1. Polymer Chain Configuration ---
# Available modes: 
# 'GPC' (Uses empirical GPC data)
# 'LOGNORMAL' (Uses theoretical log-normal distribution)
# 'FIXED' (Single fixed molecular weight)
MW_MODE=GPC

# [GPC Mode Parameters]
GPC_FILE_PATH=GPC_articaluse.xlsx
# Molar mass of the repeating unit (Divisor to convert MW to chain length N, e.g., ~44 for PEG)
MONOMER_MASS=44.0

#[LOGNORMAL Mode Parameters]
# MW_MEAN corresponds to the Number-average degree of polymerization (DPn)
MW_MEAN=2000.0
# MW_PDI corresponds to the Polydispersity Index (Mw/Mn)
MW_PDI=1.2

# [FIXED Mode Parameters]
N_SITES_FIXED=2022

# --- 2. Simulation Scale & Boundaries ---
# Number of Monte Carlo iterations (Total polymer chains)
NUM_SIMULATIONS=1000000
# Proportion of initially non-reactive (inert) sites
INERT_FRACTION=0.01978
# Probability of a successful collision leading to a reaction
ACTIVATION_PROBABILITY=0.6

# --- 3. Dual-Factor Initial Activity Values ---
INITIAL_ALPHA=1.0
INITIAL_OMEGA=1.0
ISOLATED_ACTIVITY=0.0

# --- 4. Boundary Effect Parameters (Activity Attenuation) ---
ALPHA_DECREASE=0.810827897
OMEGA_DECREASE=0.141465204
